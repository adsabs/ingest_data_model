{
  "title": "Abstract",
  "description": "Holds one abstract object, including text, language declaration, footnotes, and datalinks.  Papers with multiple languages/translations can be represented with an array of Abstract objects",
  "type": "object",
  "properties": {
    "atext": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "description": "Language of abstract, if stated"
    },
    "footnotes": {
      "type": "array",
      "description": "Array of Footnote.json objects",
      "items": {
        "$ref": "./Footnote.json"
      }
    },
    "datalinks": {
      "type": "array",
      "description": "Array of DataLink.json objects",
      "items": {
        "$ref": "./DataLink.json"
      }
    }
  }
}
